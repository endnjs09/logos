[target]
name = "codex-cli"
kind = "primary"

[provides]
instructions = "AGENTS.md"
skills = ".agents/skills"
procedures = ".agents/logos/procedures"
config = ".codex/config.toml"

[target_support.agents_md]
status = "confirmed"
notes = "Codex loads repo-level AGENTS.md automatically as durable repository guidance."

[target_support.codex_config]
status = "confirmed"
notes = "Codex supports repo-specific .codex/config.toml for durable project settings."

[target_support.approvals]
status = "confirmed"
notes = "Codex supports approval policies and sandbox configuration."

[target_support.mcp]
status = "confirmed"
notes = "Codex config.toml supports MCP server configuration."

[target_support.skills]
status = "confirmed"
notes = "Codex supports repo skills through .agents/skills; Logos installs only the nous skill as the auto-discoverable Codex skill."

[target_support.procedures]
status = "emulated"
notes = "Logos stores step-level procedure documents under .agents/logos/procedures and routes to them from nous/SKILL.md."

[target_support.commands]
status = "not_used"
notes = "Codex target uses AGENTS.md and repo skills instead of project-local commands."

[target_support.hooks]
status = "reported"
notes = "Hook integration should be verified before hard guard wiring."

[target_support.session_state]
status = "emulated"
notes = "Logos stores Nous Mode state in .logos/session/nous-state.json and initializes Codex installs with nous_mode true."
