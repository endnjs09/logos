{
  "description": "Logos Codex lifecycle hooks. Project-local hooks may require trust review before they run.",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|Edit|MultiEdit|Write|apply_patch",
        "hooks": [
          {
            "type": "command",
            "command": "python .codex/hooks/pre_tool_use.py",
            "timeout": 30,
            "statusMessage": "Checking Logos pre-tool guards"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python .codex/hooks/permission_request.py",
            "timeout": 30,
            "statusMessage": "Checking Logos permission request guards"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|Edit|MultiEdit|Write|apply_patch",
        "hooks": [
          {
            "type": "command",
            "command": "python .codex/hooks/post_tool_use.py",
            "timeout": 30,
            "statusMessage": "Recording Logos post-tool evidence"
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python .codex/hooks/post_compact.py",
            "timeout": 30,
            "statusMessage": "Restoring Logos Nous pointer after compaction"
          }
        ]
      }
    ]
  }
}
