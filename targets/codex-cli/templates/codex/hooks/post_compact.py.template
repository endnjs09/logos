#!/usr/bin/env python3
# logos-managed: true
# logos-target: codex-cli
# logos-version: {{logos_version}}
"""Logos Codex PostCompact pointer recovery hook."""

from __future__ import annotations

import json
import sys
from datetime import datetime, timezone
from pathlib import Path

POINTER_KEY = "post-compact-nous-pointer"
NOUS_SKILL = ".agents/skills/nous/SKILL.md"
PROCEDURE_DIR = ".agents/logos/procedures/"


def main() -> int:
    raw = sys.stdin.read()
    if not raw.strip():
        return 0
    try:
        payload = json.loads(raw)
    except json.JSONDecodeError as exc:
        print(json.dumps({"systemMessage": f"Logos PostCompact input could not be parsed: {exc}"}))
        return 0
    if not isinstance(payload, dict):
        return 0

    cwd = extract_cwd(payload)
    record_post_compact(cwd)
    if should_suppress_pointer(cwd):
        return 0

    print(json.dumps(to_codex_output(), ensure_ascii=False))
    return 0


def to_codex_output() -> dict[str, object]:
    return {
        "hookSpecificOutput": {
            "hookEventName": "PostCompact",
            "additionalContext": (
                "Logos Nous Mode remains active after compaction. "
                "If workflow context is missing, read `.logos/memory/resume-snapshot.md` first. "
                "If that is insufficient, read `.logos/memory/active-work.json` and "
                "`.logos/memory/run-index.json`. "
                f"Then read `{NOUS_SKILL}` or procedures under `{PROCEDURE_DIR}` only as needed."
            ),
        }
    }


def extract_cwd(payload: dict[str, object]) -> str:
    for key in ("cwd", "working_directory", "workdir"):
        value = payload.get(key)
        if isinstance(value, str) and value.strip():
            return value.strip()
    return ""


def should_suppress_pointer(cwd: str) -> bool:
    if not cwd:
        return False
    root = Path(cwd)
    if not root.exists():
        return False
    state_path = root / ".logos" / "session" / "hook-state.json"
    state = read_hook_state(state_path)
    seen = state.setdefault("seen_warnings", [])
    if POINTER_KEY in seen:
        return True
    if isinstance(seen, list):
        seen.append(POINTER_KEY)
    state["updated_at"] = datetime.now(timezone.utc).isoformat()
    write_hook_state(state_path, state)
    return False


def read_hook_state(path: Path) -> dict[str, object]:
    try:
        if not path.exists():
            return {"schema_version": 1, "seen_warnings": []}
        parsed = json.loads(path.read_text(encoding="utf-8"))
    except (OSError, json.JSONDecodeError):
        return {"schema_version": 1, "seen_warnings": []}
    if not isinstance(parsed, dict):
        return {"schema_version": 1, "seen_warnings": []}
    if not isinstance(parsed.get("seen_warnings"), list):
        parsed["seen_warnings"] = []
    parsed.setdefault("schema_version", 1)
    return parsed


def write_hook_state(path: Path, state: dict[str, object]) -> None:
    try:
        path.parent.mkdir(parents=True, exist_ok=True)
        path.write_text(json.dumps(state, indent=2, ensure_ascii=False) + "\n", encoding="utf-8")
    except OSError:
        return


def record_post_compact(cwd: str) -> None:
    if not cwd:
        return
    root = Path(cwd)
    if not root.exists():
        return
    event = {
        "schema_version": 1,
        "recorded_at": datetime.now(timezone.utc).isoformat(),
        "hook_event_name": "PostCompact",
        "summary": "context compacted; resume snapshot should be read before raw logs if context is unclear",
    }
    path = root / ".logos" / "evidence" / "hook-events.jsonl"
    try:
        path.parent.mkdir(parents=True, exist_ok=True)
        with path.open("a", encoding="utf-8") as stream:
            stream.write(json.dumps(event, ensure_ascii=False, sort_keys=True) + "\n")
    except OSError:
        return


if __name__ == "__main__":
    raise SystemExit(main())
