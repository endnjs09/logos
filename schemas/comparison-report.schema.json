{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://logos.local/schemas/comparison-report.schema.json",
  "title": "Comparison Report",
  "type": "object",
  "required": ["suite_id", "conditions", "summary"],
  "properties": {
    "suite_id": { "type": "string" },
    "conditions": { "type": "array", "items": { "type": "string" } },
    "summary": { "type": "object" },
    "metrics": { "type": "object" }
  }
}
