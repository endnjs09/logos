{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://logos.local/schemas/guards-manifest.schema.json",
  "title": "Logos Guards Manifest",
  "type": "object",
  "required": [
    "schema_version",
    "logos_version",
    "generated_at",
    "selection_policy",
    "guard_count",
    "guards"
  ],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "logos_version": { "type": "string" },
    "generated_at": { "type": "string" },
    "selection_policy": {
      "type": "object",
      "required": ["default_status", "raw_assets_selected", "target", "profile"],
      "properties": {
        "default_status": { "type": "string", "const": "active" },
        "raw_assets_selected": { "type": "boolean", "const": false },
        "target": { "type": "string" },
        "profile": { "type": "string" }
      },
      "additionalProperties": false
    },
    "guard_count": { "type": "integer", "minimum": 0 },
    "guards": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "path",
          "status",
          "selected",
          "has_frontmatter",
          "enforcement",
          "enforcement_status",
          "decision",
          "risk_level",
          "severity",
          "sha256"
        ],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "path": { "type": "string", "minLength": 1 },
          "status": { "type": "string", "minLength": 1 },
          "selected": { "type": "boolean" },
          "has_frontmatter": { "type": "boolean" },
          "enforcement": { "type": ["string", "null"] },
          "enforcement_status": { "type": ["string", "null"] },
          "decision": { "type": ["string", "null"] },
          "risk_level": { "type": ["string", "null"] },
          "severity": { "type": ["integer", "null"] },
          "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
