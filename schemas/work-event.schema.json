{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://logos.local/schemas/work-event.schema.json",
  "title": "Logos Work Event",
  "type": "object",
  "required": ["schema_version", "recorded_at"],
  "properties": {
    "schema_version": { "const": 1 },
    "run_id": { "type": "string" },
    "recorded_at": { "type": "string" },
    "command": { "type": "string" },
    "path": { "type": "string" },
    "guard_id": { "type": "string" },
    "decision": { "type": "string" },
    "summary": { "type": "string" }
  }
}
