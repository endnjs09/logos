{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://logos.local/schemas/spec-result.schema.json",
  "title": "Logos Spec Result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "complexity",
    "spec_type",
    "source_refs",
    "one_line_plan",
    "mini_spec",
    "structured_spec",
    "blocking_open_questions",
    "interview_draft_update",
    "next_step"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "complexity": {
      "enum": ["low", "middle", "high"]
    },
    "spec_type": {
      "enum": ["low_fast_path", "mini_spec", "structured_spec"]
    },
    "source_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "one_line_plan": {
      "type": "string"
    },
    "mini_spec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["goal", "success_criteria", "key_edge_cases", "excluded_scope"],
      "properties": {
        "goal": {
          "type": "string"
        },
        "success_criteria": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "key_edge_cases": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "excluded_scope": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "structured_spec": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "user_story",
        "confirmed_requirements",
        "success_criteria",
        "quality_gates",
        "constraints",
        "edge_cases",
        "excluded_scope",
        "open_questions"
      ],
      "properties": {
        "user_story": {
          "type": "string"
        },
        "confirmed_requirements": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "success_criteria": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "quality_gates": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "constraints": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "edge_cases": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "excluded_scope": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "open_questions": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "blocking_open_questions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "interview_draft_update": {
      "type": "object",
      "additionalProperties": false,
      "required": ["confirmed_decisions", "open_questions", "excluded_scope"],
      "properties": {
        "confirmed_decisions": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "open_questions": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "excluded_scope": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "next_step": {
      "enum": ["task_plan", "clarification"]
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "spec_type": {
            "const": "low_fast_path"
          }
        },
        "required": ["spec_type"]
      },
      "then": {
        "properties": {
          "complexity": {
            "const": "low"
          },
          "one_line_plan": {
            "minLength": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "spec_type": {
            "const": "mini_spec"
          }
        },
        "required": ["spec_type"]
      },
      "then": {
        "properties": {
          "complexity": {
            "const": "middle"
          },
          "mini_spec": {
            "properties": {
              "goal": {
                "minLength": 1
              },
              "success_criteria": {
                "minItems": 1
              },
              "excluded_scope": {
                "minItems": 1
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "spec_type": {
            "const": "structured_spec"
          }
        },
        "required": ["spec_type"]
      },
      "then": {
        "properties": {
          "complexity": {
            "const": "high"
          },
          "structured_spec": {
            "properties": {
              "user_story": {
                "minLength": 1
              },
              "confirmed_requirements": {
                "minItems": 1
              },
              "success_criteria": {
                "minItems": 1
              },
              "quality_gates": {
                "minItems": 1
              },
              "excluded_scope": {
                "minItems": 1
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "next_step": {
            "const": "task_plan"
          }
        },
        "required": ["next_step"]
      },
      "then": {
        "properties": {
          "blocking_open_questions": {
            "maxItems": 0
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "next_step": {
            "const": "clarification"
          }
        },
        "required": ["next_step"]
      },
      "then": {
        "properties": {
          "blocking_open_questions": {
            "minItems": 1
          }
        }
      }
    }
  ]
}
