{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://logos.local/schemas/hook-state.schema.json",
  "title": "Logos Hook State",
  "type": "object",
  "required": ["schema_version", "seen_warnings"],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "seen_warnings": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "updated_at": {
      "type": "string"
    }
  },
  "additionalProperties": true
}
